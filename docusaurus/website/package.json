{
  "name": "website",
  "version": "5.6.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "prebuild": "./scripts/download-schema.sh && ./scripts/generate-markdown.sh",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "eslint --cache '../docs/**/*.{md,mdx}'",
    "typecheck": "tsc",
    "test": "vitest",
    "test:ci": "vitest --run"
  },
  "dependencies": {
    "@coffeeandfun/remove-pii": "2.0.0",
    "@docusaurus/core": "3.10.1",
    "@docusaurus/plugin-client-redirects": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@grafana/faro-web-sdk": "2.1.0",
    "@mdx-js/react": "3.1.0",
    "clsx": "2.1.1",
    "cookiejs": "2.1.3",
    "debounce": "3.0.0",
    "docusaurus-lunr-search": "3.6.0",
    "gridsome-remark-figure-caption": "1.2.2",
    "prism-react-renderer": "2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/remark-plugin-npm2yarn": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@signalwire/docusaurus-plugin-llms-txt": "2.0.0-alpha.7",
    "dotenv": "17.3.1",
    "raw-loader": "4.0.2",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "nx": {
    "targets": {
      "build": {
        "inputs": [
          "{projectRoot}/**/*",
          "{workspaceRoot}/docusaurus/docs/*.@(md|mdx|json)",
          "{workspaceRoot}/docusaurus/docs/**/*.@(md|mdx|json)"
        ],
        "outputs": [
          "{projectRoot}/build"
        ]
      }
    }
  }
}
